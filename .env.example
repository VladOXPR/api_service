# OpenAI API Key for captcha solving
OPENAI_API_KEY=your_openai_api_key_here

# Energo Dashboard Credentials
ENERGO_USERNAME=your_energo_username
ENERGO_PASSWORD=your_energo_password

# Stripe (for /stripe/charges and /rents/*)
STRIPE_SECRET_KEY=sk_live_your_key_here

# Shared secret for /pos/* endpoints (POST /pos/start_rent, PATCH /pos/end_rent, GET /pos/rents).
# Generate with: node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
# Without this set, every /pos/* request returns 503.
POS_API_TOKEN=replace_with_a_strong_random_value
